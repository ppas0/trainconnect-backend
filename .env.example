# TrainConnect Europe – Umgebungsvariablen
# Kopiere diese Datei zu .env und fülle alle Werte aus
# NIEMALS .env in Git committen!

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── JWT ───────────────────────────────────────────────────────────────────────
# Mindestens 32 zufällige Zeichen: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=HIER_SICHEREN_ZUFALLSKEY_EINTRAGEN

# ── Stripe ────────────────────────────────────────────────────────────────────
# Test-Keys: https://dashboard.stripe.com/test/apikeys
# Live-Keys:  https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_XXXX
STRIPE_PUBLISHABLE_KEY=pk_live_XXXX
STRIPE_WEBHOOK_SECRET=whsec_XXXX

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
DATABASE_URL=postgresql://trainconnect:PASSWORD@HOST:5432/trainconnect

# ── SendGrid ──────────────────────────────────────────────────────────────────
SENDGRID_API_KEY=SG.XXXX
SENDGRID_FROM_EMAIL=noreply@trainconnect.eu
SENDGRID_FROM_NAME=TrainConnect Europe

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://trainconnect.eu,https://www.trainconnect.eu
